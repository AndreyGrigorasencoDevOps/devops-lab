# =========================
# App (Node API)
# =========================
PORT=3000
SERVICE_NAME=node-api
LOG_LEVEL=info

# Optional (uncomment if you want to force it)
# NODE_ENV=development


# =========================
# Database (Postgres)
# These values are used by:
# - host-run Node app (`npm run dev`)
# - the db container (POSTGRES_*)
# - the api container in `docker compose up --build`
# =========================
# Host-first default: local Node process connects to Postgres published by Docker.
# `docker compose` overrides DB_HOST to `db` for the api container automatically.
DB_HOST=127.0.0.1
DB_PORT=5432
LOCAL_DB_PORT=5432

# Credentials (DO NOT commit real values; keep them empty here)
DB_USER=
DB_PASSWORD=

# Default DB name is fine for local dev
DB_NAME=tasksdb

# Keep DB_PORT and LOCAL_DB_PORT aligned if you publish Postgres on a non-default host port.
